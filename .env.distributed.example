# Copy to .env.distributed on every participant machine and edit the hosts.
#
# All participants must use the same values for NODE_COUNT, NODE*_HOST, and
# NODE*_P2P_PORT because these values are written into the shared enode list.

NODE_COUNT=5

# Example 3-person split:
# - Person A runs node1 and node2 at 10.8.0.1
# - Person B runs node3 at 10.8.0.2
# - Person C runs node4 and node5 at 10.8.0.3
NODE1_HOST=10.8.0.1
NODE2_HOST=10.8.0.1
NODE3_HOST=10.8.0.2
NODE4_HOST=10.8.0.3
NODE5_HOST=10.8.0.3

# P2P ports must be unique per machine when one person runs multiple validators.
NODE1_P2P_PORT=30303
NODE2_P2P_PORT=30304
NODE3_P2P_PORT=30305
NODE4_P2P_PORT=30306
NODE5_P2P_PORT=30307

# Local RPC/WS ports are only for the machine running that validator.
NODE1_RPC_HTTP_PORT=8545
NODE1_RPC_WS_PORT=8546
NODE2_RPC_HTTP_PORT=8547
NODE2_RPC_WS_PORT=8548
NODE3_RPC_HTTP_PORT=8549
NODE3_RPC_WS_PORT=8550
NODE4_RPC_HTTP_PORT=8551
NODE4_RPC_WS_PORT=8552
NODE5_RPC_HTTP_PORT=8553
NODE5_RPC_WS_PORT=8554

# Explorer ports used only on the machine running node1.
# BLOCKSCOUT_PORT is the browser-facing proxy.
BLOCKSCOUT_PORT=3000
BLOCKSCOUT_BACKEND_PORT=4000
BLOCKSCOUT_FRONTEND_PUBLIC_PROTOCOL=https
BLOCKSCOUT_FRONTEND_PUBLIC_HOST=blockscout.denis.my.id
BLOCKSCOUT_FRONTEND_PUBLIC_PORT=
BLOCKSCOUT_FRONTEND_PUBLIC_WS_PROTOCOL=wss
POSTGRES_PORT=5432
